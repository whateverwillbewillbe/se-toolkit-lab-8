{
  "agents": {
    "defaults": {
      "workspace": "/app/workspace",
      "model": "coder-model",
      "provider": "custom",
      "max_tool_iterations": 20,
      "temperature": 0.1
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 8765,
      "allow_from": ["*"]
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": false
    }
  },
  "tools": {
    "exec": {
      "enable": true,
      "timeout": 30
    }
  }
}
